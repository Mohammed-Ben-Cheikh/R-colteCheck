rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /farmers/{farmerId} {
      allow read, write: if request.auth != null && request.auth.uid == farmerId;

      match /parcels/{parcelId} {
        allow read, write: if request.auth != null && request.auth.uid == farmerId;
      }

      match /harvests/{harvestId} {
        allow read, write: if request.auth != null && request.auth.uid == farmerId;
      }
    }
  }
}
